# ─── Required ─────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
JWT_SECRET=CHANGE-ME-minimum-32-characters-long!!
DB_NAME=regal_park_villas

# ─── Security ─────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# REQUIRED — no default. Without this, CORS blocks all cross-origin requests.
# Use "*" ONLY for local development. In production, list exact origins.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── Feature Flags ────────────────────────────────────────
# Set to "true" to seed demo users and sample data on startup.
# Defaults to "false". MUST be "false" or absent in production.
SEED_DEMO_DATA=true

# ─── Redis (Optional) ─────────────────────────────────────
# Used for distributed rate limiting across multiple backend instances.
# If not set, rate limiting falls back to in-memory (single-instance only).
# REDIS_URL=redis://localhost:6379/0
