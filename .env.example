# ═══════════════════════════════════════════════════════════
#  Regal Park Villas — Environment Variables
#  Copy this to Vercel Environment Variables settings
# ═══════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────

# MongoDB Atlas connection string (free tier: mongodb.com/cloud/atlas)
# IMPORTANT: No special chars (!@#$) in the password
MONGO_URL=mongodb+srv://rpv_admin:YourPassword@cluster0.xxxxx.mongodb.net/regal_park_villas?retryWrites=true&w=majority

# JWT signing secret (minimum 32 characters)
JWT_SECRET=RegalParkVillasSterlitee2026SecretKeyForJWT

# Set to "true" to populate demo data on first boot
SEED_DEMO_DATA=true

# CORS origins (* = allow all, fine for demo/pilot)
ALLOWED_ORIGINS=*

# ── OPTIONAL ──────────────────────────────────────────────

# Database name (default: regal_park_villas)
# DB_NAME=regal_park_villas

# Redis URL for distributed rate limiting (not needed for Vercel)
# REDIS_URL=redis://localhost:6379/0
